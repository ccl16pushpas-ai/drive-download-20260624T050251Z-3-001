FROM &quot;03_aum_by_fund_house&quot;
ORDER BY aum_crore DESC;
SELECT fund_house, num_schemes
FROM &quot;03_aum_by_fund_house&quot;
ORDER BY num_schemes DESC;
SELECT AVG(aum_crore) AS avg_aum
FROM &quot;03_aum_by_fund_house&quot;;
SELECT SUM(aum_crore) AS total_aum
FROM &quot;03_aum_by_fund_house&quot;;
SELECT fund_house, aum_crore
FROM &quot;03_aum_by_fund_house&quot;
ORDER BY aum_crore DESC
LIMIT 5;
SELECT fund_house, num_schemes
FROM &quot;03_aum_by_fund_house&quot;
ORDER BY num_schemes ASC;
SELECT date, fund_house, aum_crore
FROM &quot;03_aum_by_fund_house&quot;
ORDER BY date DESC;
