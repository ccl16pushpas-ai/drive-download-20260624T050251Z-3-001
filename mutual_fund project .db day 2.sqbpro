FROM &quot;03_aum_by_fund_house&quot;
ORDER BY 2 DESC
LIMIT 5;
SELECT *
FROM &quot;04_monthly_sip_inflows&quot;;
SELECT *
FROM &quot;05_category_inflows&quot;
ORDER BY 2 DESC
LIMIT 5;
SELECT *
FROM &quot;06_industry_folio_count&quot;
ORDER BY 2 DESC;
SELECT *
